# --- PostgreSQL ---
POSTGRES_USER=mundial
# Générez une valeur forte, propre à votre environnement (jamais "changeme" ni aucune
# valeur triviale) : par ex. python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
POSTGRES_DB=mundial_pronos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Doit reprendre exactement la même valeur que POSTGRES_PASSWORD ci-dessus.
DATABASE_URL=postgresql+psycopg://mundial:<POSTGRES_PASSWORD>@postgres:5432/mundial_pronos

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
# Génère et valide les JWT : une valeur triviale ou partagée permettrait de forger des
# jetons valides. Générez une valeur forte, ex. : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AI_SERVICE_URL=http://ai-service:8001
CORS_ORIGINS=http://localhost:5173
# Clé API-Football (api-sports.io) : requise pour l'import du contexte sportif
# (entraîneurs, effectifs, compositions -- services/team_details_seed.py et lineups_seed.py)
FOOTBALL_API_KEY=
# Réinitialisation de mot de passe : "logging" écrit le lien dans les logs du serveur
# (développement, défaut) ; un fournisseur réel (ex. "resend") se branche au déploiement.
EMAIL_BACKEND=logging
# Base des liens envoyés aux utilisateurs (ex. lien de réinitialisation).
FRONTEND_BASE_URL=http://localhost:5173
# Équipes présentes en base mais absentes du dataset du service IA (liste séparée par des
# virgules). Exclues du tirage d'entraînement ; en compétitif l'IA leur sert une prédiction
# de repli neutre. Régénérer avec `python -m scripts.check_ai_team_coverage`.
AI_UNKNOWN_TEAMS=Curaçao

# --- AI service ---
AI_SERVICE_PORT=8001

# --- Frontend (Vite) ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000